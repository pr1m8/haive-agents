#!/usr/bin/env python3
"""SimpleAgent v3 Comprehensive Example and Documentation.

This module demonstrates the complete functionality of SimpleAgent v3 with:
- Real LLM execution (no mocks)
- Tool integration patterns
- Structured output models
- Meta-state capabilities
- Recompilation system
- Debug and verbose modes

The examples show production-ready patterns for building AI agents with
the Haive framework's enhanced architecture.

Examples:
    Basic agent usage::

        from haive.agents.simple.agent_v3 import SimpleAgentV3
        from haive.core.engine.aug_llm import AugLLMConfig

        agent = SimpleAgentV3(
            name="assistant",
            engine=AugLLMConfig(temperature=0.7)
        )
        response = agent.run("Hello, how can you help me?")

    With tools and structured output::

        @tool
        def calculator(expression: str) -> str:
            return str(eval(expression))

        class TaskResult(BaseModel):
            answer: str = Field(description="The calculated result")
            confidence: float = Field(description="Confidence in result")

        agent = SimpleAgentV3(
            name="math_agent",
            engine=AugLLMConfig(
                tools=[calculator],
                structured_output_model=TaskResult
            )
        )

Author:
    Haive Development Team

Version:
    3.0.0

License:
    MIT
"""

import asyncio
import logging
from datetime import datetime
from typing import List, Union

from haive.core.engine.aug_llm import AugLLMConfig
from haive.core.models.llm.base import DeepSeekLLMConfig
from haive.core.schema.prebuilt.meta_state import MetaStateSchema
from langchain_core.messages import AIMessage, HumanMessage
from langchain_core.tools import tool
from pydantic import BaseModel, Field

# Core Haive imports
from haive.agents.simple.agent_v3 import SimpleAgentV3

# Configure logging for examples
logging.basicConfig(level=logging.INFO, format="%(levelname)s: %(message)s")
logger = logging.getLogger(__name__)


# ============================================================================
# STRUCTURED OUTPUT MODELS
# ============================================================================


class TaskAnalysis(BaseModel):
    """Structured output model for task analysis results.

    This model defines the expected structure for AI responses when analyzing
    tasks or problems. Used with structured output to ensure consistent,
    parseable responses.

    Attributes:
        task_type: Classification of the task (e.g., "calculation", "research")
        complexity: Complexity level from 1-10
        steps_required: List of steps needed to complete the task
        estimated_time: Estimated completion time in minutes
        confidence: AI's confidence in the analysis (0.0-1.0)

    Examples:
        Creating a task analysis::

            analysis = TaskAnalysis(
                task_type="calculation",
                complexity=3,
                steps_required=["Parse expression", "Calculate", "Format result"],
                estimated_time=2,
                confidence=0.95
            )
    """

    task_type: str = Field(
        description="Type of task (calculation, research, analysis, etc.)"
    )
    complexity: int = Field(ge=1, le=10, description="Task complexity on scale of 1-10")
    steps_required: List[str] = Field(
        description="List of steps needed to complete the task"
    )
    estimated_time: int = Field(
        ge=1, description="Estimated completion time in minutes"
    )
    confidence: float = Field(
        ge=0.0, le=1.0, description="AI confidence in this analysis (0.0-1.0)"
    )


class CalculationResult(BaseModel):
    """Structured output model for mathematical calculations.

    Defines the expected structure for calculation results, ensuring
    consistent formatting and metadata capture.

    Attributes:
        expression: The original mathematical expression
        result: The calculated numerical result
        steps: Step-by-step calculation process
        is_exact: Whether the result is exact or approximate

    Examples:
        Creating a calculation result::

            calc = CalculationResult(
                expression="15 * 23 + 7",
                result=352,
                steps=["15 * 23 = 345", "345 + 7 = 352"],
                is_exact=True
            )
    """

    expression: str = Field(description="Original mathematical expression")
    result: Union[int, float] = Field(description="Calculated result")
    steps: List[str] = Field(description="Step-by-step calculation process")
    is_exact: bool = Field(description="Whether result is exact or approximated")


# ============================================================================
# TOOL DEFINITIONS
# ============================================================================


@tool
def calculator(expression: str) -> str:
    """Perform mathematical calculations safely.

    Evaluates mathematical expressions and returns the result as a string.
    Supports basic arithmetic operations (+, -, *, /, **, %, //).

    Args:
        expression: Mathematical expression to evaluate (e.g., "15 * 23 + 7")

    Returns:
        String representation of the calculation result

    Raises:
        ValueError: If expression contains invalid syntax
        ZeroDivisionError: If division by zero is attempted

    Examples:
        Basic calculations::

            result = calculator("15 * 23")  # Returns "345"
            result = calculator("100 / 3")   # Returns "33.333333333333336"

    Note:
        This tool uses Python's eval() function with basic safety measures.
        In production, consider using a more secure expression evaluator.
    """
    try:
        # Basic safety: only allow specific characters
        allowed_chars = set("0123456789+-*/.() %")
        if not all(c in allowed_chars for c in expression):
            return f"Error: Invalid characters in expression '{expression}'"

        result = eval(expression)
        return str(result)
    except ZeroDivisionError:
        return f"Error: Division by zero in expression '{expression}'"
    except Exception as e:
        return f"Error calculating '{expression}': {str(e)}"


@tool
def current_time() -> str:
    """Get the current date and time.

    Returns the current date and time in a human-readable format.
    Useful for agents that need temporal context.

    Returns:
        Current date and time as formatted string

    Examples:
        Getting current time::

            time_str = current_time()  # Returns "2025-01-23 14:30:45"
    """
    return datetime.now().strftime("%Y-%m-%d %H:%M:%S")


@tool
def word_counter(text: str) -> str:
    """Count words, characters, and lines in text.

    Analyzes text and returns detailed statistics about word count,
    character count, and line count.

    Args:
        text: Text to analyze

    Returns:
        Formatted string with text statistics

    Examples:
        Analyzing text::

            stats = word_counter("Hello world")
            # Returns: "Words: 2, Characters: 11, Lines: 1"
    """
    if not text.strip():
        return "Words: 0, Characters: 0, Lines: 0"

    words = len(text.split())
    chars = len(text)
    lines = len(text.splitlines())

    return f"Words: {words}, Characters: {chars}, Lines: {lines}"


# ============================================================================
# EXAMPLE FUNCTIONS
# ============================================================================


def example_basic_agent() -> None:
    """Demonstrate basic SimpleAgent v3 usage.

    Shows the simplest way to create and use a SimpleAgent v3 with:
    - Default configuration
    - Real LLM execution
    - Basic conversation

    This example uses no tools or structured output, just pure conversation.
    """
    print("\n" + "=" * 80)
    print("🚀 EXAMPLE 1: Basic SimpleAgent v3 Usage")
    print("=" * 80)

    # Create simple agent with default settings
    agent = SimpleAgentV3(
        name="basic_assistant",
        engine=AugLLMConfig(
            temperature=0.7, max_tokens=150, llm_config=DeepSeekLLMConfig()
        ),
        debug=True,
        verbose=True,
    )

    logger.info(f"Created agent: {agent.name}")
    logger.info(f"Engine type: {type(agent.engine).__name__}")
    logger.info(f"State schema: {agent.state_schema.__name__}")

    # Test basic conversation
    message = "Hello! Tell me a brief fun fact about artificial intelligence."

    print(f"\n📨 User: {message}")
    print("\n" + "-" * 60)

    # Execute agent
    result = agent.run(message, debug=True)

    print("-" * 60)

    # Extract and display response
    if hasattr(result, "messages"):
        for msg in reversed(result.messages):
            if isinstance(msg, AIMessage):
                print(f"🤖 AI: {msg.content}")
                break

    print("\n✅ Basic agent example complete!")


def example_agent_with_tools() -> None:
    """Demonstrate SimpleAgent v3 with tool integration.

    Shows how to create an agent with multiple tools:
    - Mathematical calculator
    - Current time provider
    - Text analysis tool

    The agent can dynamically choose which tools to use based on the query.
    """
    print("\n" + "=" * 80)
    print("🛠️  EXAMPLE 2: SimpleAgent v3 with Tools")
    print("=" * 80)

    # Create agent with multiple tools
    agent = SimpleAgentV3(
        name="tool_agent",
        engine=AugLLMConfig(
            temperature=0.3,  # Lower temperature for tool usage
            max_tokens=200,
            tools=[calculator, current_time, word_counter],
            llm_config=DeepSeekLLMConfig(),
        ),
        debug=True,
        verbose=True,
    )

    logger.info(f"Created tool agent with {len(agent.engine.tools)} tools")
    tool_names = [t.name for t in agent.engine.tools]
    logger.info(f"Available tools: {', '.join(tool_names)}")

    # Test tool usage
    queries = [
        "What's the current time?",
        "Calculate 15 * 23 + 7 for me",
        "Count the words in this sentence: 'The quick brown fox jumps over the lazy dog'",
    ]

    for i, query in enumerate(queries, 1):
        print(f"\n📨 Query {i}: {query}")
        print("-" * 40)

        result = agent.run(query, debug=True)

        # Extract response
        if hasattr(result, "messages"):
            for msg in reversed(result.messages):
                if isinstance(msg, AIMessage):
                    print(f"🤖 Response: {msg.content}")
                    break

        print()

    print("✅ Tool agent example complete!")


def example_structured_output() -> None:
    """Demonstrate SimpleAgent v3 with structured output models.

    Shows how to use Pydantic models to get structured, typed responses:
    - Task analysis with structured fields
    - Calculation results with metadata
    - Type-safe output processing

    This ensures AI responses follow a specific schema and can be processed
    programmatically.
    """
    print("\n" + "=" * 80)
    print("📋 EXAMPLE 3: SimpleAgent v3 with Structured Output")
    print("=" * 80)

    # Create agent with structured output model
    agent = SimpleAgentV3(
        name="structured_agent",
        engine=AugLLMConfig(
            temperature=0.2,  # Low temperature for consistent structure
            max_tokens=300,
            structured_output_model=TaskAnalysis,
            tools=[calculator, current_time],
            llm_config=DeepSeekLLMConfig(),
        ),
        debug=True,
        verbose=True,
    )

    logger.info("Created structured output agent")
    logger.info(f"Output model: {TaskAnalysis.__name__}")
    logger.info(f"Model fields: {list(TaskAnalysis.model_fields.keys())}")

    # Test structured output
    task_query = """
    Analyze this task: 'Build a web application that calculates mortgage payments 
    and displays amortization schedules with interactive charts'
    """

    print("\n📨 Task Analysis Request:")
    print(f"   {task_query.strip()}")
    print("\n" + "-" * 60)

    result = agent.run(task_query, debug=True)

    print("-" * 60)

    # Process structured output
    if hasattr(result, "messages"):
        for msg in reversed(result.messages):
            if isinstance(msg, AIMessage):
                print("🤖 Structured Analysis:")
                print(f"   Raw response: {msg.content[:100]}...")

                # In a real implementation, the structured output would be
                # automatically parsed into the TaskAnalysis model
                # For demonstration, we show what the structure would look like
                print("\n📊 Expected Structure (TaskAnalysis:")
                print("   - task_type: Web application development")
                print("   - complexity: 7-8")
                print("   - steps_required: [Design, Backend, Frontend, Testing]")
                print("   - estimated_time: 120-240 minutes")
                print("   - confidence: 0.8-0.9")
                break

    print("\n✅ Structured output example complete!")


def example_meta_state_integration() -> None:
    """Demonstrate SimpleAgent v3 with MetaStateSchema integration.

    Shows how to embed agents in MetaStateSchema for:
    - Execution tracking and history
    - Agent state management
    - Meta-capabilities and composition
    - Dynamic agent replacement

    This enables agents to be used as components in larger systems.
    """
    print("\n" + "=" * 80)
    print("🧠 EXAMPLE 4: Meta-State Integration")
    print("=" * 80)

    # Create base agent
    base_agent = SimpleAgentV3(
        name="meta_embedded_agent",
        engine=AugLLMConfig(
            temperature=0.6,
            max_tokens=150,
            tools=[calculator, current_time],
            llm_config=DeepSeekLLMConfig(),
        ),
        debug=True,
    )

    logger.info(f"Created base agent: {base_agent.name}")

    # Embed in MetaStateSchema
    meta_state = MetaStateSchema.from_agent(
        agent=base_agent,
        initial_state={"session_id": "demo_session_001"},
        graph_context={"purpose": "demonstration", "version": "3.0"},
    )

    logger.info("Embedded agent in MetaStateSchema")
    logger.info(f"Agent type: {meta_state.agent_type}")
    logger.info(f"Execution status: {meta_state.execution_status}")

    # Test meta-execution
    queries = ["What's 25 * 4?", "What time is it now?"]

    for i, query in enumerate(queries, 1):
        print(f"\n📨 Meta-Query {i}: {query}")
        print("-" * 40)

        # Execute through meta state (async)
        async def run_meta_query():
            return await meta_state.execute_agent(
                input_data={"messages": [HumanMessage(content=query)]},
                update_state=True,
            )

        # Run async execution
        meta_result = asyncio.run(run_meta_query())

        print("🧠 Meta-execution complete")
        print(f"   Status: {meta_result.get('status', 'unknown')}")
        print(f"   Execution count: {meta_state.execution_count}")

        # Get execution summary
        summary = meta_state.get_execution_summary()
        print(f"   Total executions: {summary['execution_count']}")
        print(f"   Current status: {summary['current_status']}")

    print("\n✅ Meta-state integration example complete!")


def example_recompilation_system() -> None:
    """Demonstrate SimpleAgent v3 recompilation capabilities.

    Shows how the recompilation system works:
    - Hash-based change detection
    - Dynamic tool addition/removal
    - Automatic graph rebuilding
    - State preservation during recompilation

    This enables agents to adapt their capabilities at runtime.
    """
    print("\n" + "=" * 80)
    print("🔄 EXAMPLE 5: Recompilation System")
    print("=" * 80)

    # Create initial agent with basic tools
    agent = SimpleAgentV3(
        name="recompilable_agent",
        engine=AugLLMConfig(
            temperature=0.4,
            max_tokens=150,
            tools=[calculator, current_time],  # Start with 2 tools
            llm_config=DeepSeekLLMConfig(),
        ),
        debug=True,
        verbose=True,
    )

    logger.info(f"Created agent with {len(agent.engine.tools)} tools")
    initial_tools = [t.name for t in agent.engine.tools]
    logger.info(f"Initial tools: {', '.join(initial_tools)}")

    # Test initial capabilities
    print("\n📨 Initial test: 'What's 10 * 5 and what time is it?'")
    result1 = agent.run("What's 10 * 5 and what time is it?", debug=True)

    # Extract response
    if hasattr(result1, "messages"):
        for msg in reversed(result1.messages):
            if isinstance(msg, AIMessage):
                print(f"🤖 Initial response: {msg.content}")
                break

    print("\n🔄 Adding word_counter tool and triggering recompilation...")

    # Add new tool (this should trigger recompilation)
    agent.engine.tools.append(word_counter)

    # Mark for recompilation
    if hasattr(agent, "mark_for_recompile"):
        agent.mark_for_recompile("Added word_counter tool")
        logger.info("Marked agent for recompilation")

    logger.info(f"Agent now has {len(agent.engine.tools)} tools")
    updated_tools = [t.name for t in agent.engine.tools]
    logger.info(f"Updated tools: {', '.join(updated_tools)}")

    # Test new capabilities
    print(
        "\n📨 Post-recompilation test: 'Count words in: Hello world from recompiled agent'"t'""
    )
    result2 = agent.run(
        "Count the words in this text: 'Hello world from recompiled agent'", debug=True
    )

    # Extract response
    if hasattr(result2, "messages"):
        for msg in reversed(result2.messages):
            if isinstance(msg, AIMessage):
                print(f"🤖 Post-recompilation response: {msg.content}")
                break

    # Show recompilation status
    if hasattr(agent, "needs_recompile"):
        print("\n📊 Recompilation Status:")
        print(f"   Needs recompile: {getattr(agent, 'needs_recompile', 'N/A')}")
        print(
            f"   Last recompile reason: {getattr(agent, 'last_recompile_reason', 'N/A')}"
        )

    print("\n✅ Recompilation system example complete!")


def main() -> None:
    """Run all SimpleAgent v3 examples in sequence.

    Executes all example functions to demonstrate the complete feature set
    of SimpleAgent v3, including:
    - Basic usage patterns
    - Tool integration
    - Structured output
    - Meta-state capabilities
    - Recompilation system

    Each example is self-contained and demonstrates specific functionality.
    """
    print("🎯 SIMPLEAGENT V3 COMPREHENSIVE EXAMPLES")
    print("=" * 80)
    print("Demonstrating all features with real LLM execution (no mocks)")
    print("=" * 80)

    try:
        # Run all examples
        example_basic_agent()
        example_agent_with_tools()
        example_structured_output()
        example_meta_state_integration()
        example_recompilation_system()

        print("\n" + "=" * 80)
        print("🎉 ALL EXAMPLES COMPLETED SUCCESSFULLY!")
        print("=" * 80)
        print("\nKey features demonstrated:")
        print("✅ Real LLM execution with debug output")
        print("✅ Tool integration and dynamic selection")
        print("✅ Structured output with Pydantic models")
        print("✅ Meta-state embedding and execution tracking")
        print("✅ Recompilation system with change detection")
        print("\nSimpleAgent v3 is production-ready! 🚀")

    except KeyboardInterrupt:
        print("\n\n⚠️  Examples interrupted by user")
    except Exception as e:
        print(f"\n\n❌ Example execution failed: {e}")
        logger.exception("Example execution error")


if __name__ == "__main__":
    main()